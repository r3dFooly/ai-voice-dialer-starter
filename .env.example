# =============================================================================
# ai-voice-dialer-starter — environment template
# Copy to backend/.env (backend) and dashboard/.env.local (dashboard).
# NEVER commit a filled-in .env. Every value below must be YOUR fresh account.
# =============================================================================

# --- Branding / vertical (BLANK — fill for your project) ---------------------
COMPANY_NAME=
AGENT_PERSONA_NAME=            # the voice agent's name, e.g. "Alex"
SEGMENT_LABEL=Lead             # generic label for a lead's category/business line

# --- Voice provider: Retell (https://retell.ai) ------------------------------
RETELL_API_KEY=
RETELL_AGENT_ID=               # the Retell agent wired to this server's custom-LLM websocket
RETELL_FROM_NUMBER=            # default outbound caller ID (E.164), e.g. +15551234567
                              # (can also be set via agency_settings.retell_default_from_number)

# --- LLM (OpenAI-compatible /v1/chat/completions) ----------------------------
# Works with OpenAI, a LiteLLM proxy, or any OpenAI-compatible gateway.
# For Anthropic, front it with an OpenAI-compatible gateway or a LiteLLM proxy.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=12000

# --- Database: Supabase (new project per business) ---------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=    # server-only — never expose to the browser

# --- Lead source adapter -----------------------------------------------------
# supabase = leads live in retell_call_queue (default, self-contained)
# ghl      = pull/writeback via GoHighLevel (implement adapters/leadSource/ghl.stub.js)
LEAD_SOURCE=supabase

# --- Warm transfer (BLANK — set to enable live handoff) ----------------------
TRANSFER_PRIMARY=             # E.164 number a hot lead transfers to
TRANSFER_FALLBACK=           # E.164 fallback number

# --- Notifier (generic outbound webhook for transfer / hot-lead alerts) ------
# Fire-and-forget JSON POST. Point at Slack/Discord/Teams/your own endpoint.
NOTIFY_WEBHOOK_URL=

# --- Twilio Lookup enrichment (OPTIONAL — off without creds) -----------------
ENABLE_TWILIO_LOOKUP=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Compliance module (OPTIONAL — OFF by default) ---------------------------
# true => enforces consent + calling-window + DNC (and REQUIRES migration 0007).
# READ docs/COMPLIANCE-MODULE.md and understand TCPA before enabling for real dials.
COMPLIANCE_MODULE_ENABLED=false

# --- Server / scheduler tunables ---------------------------------------------
PORT=4002                                 # backend HTTP + Retell custom-LLM websocket
SCHEDULER_POLL_INTERVAL_MS=15000          # how often the scheduler drains the queue
RETELL_CANDIDATE_BATCH_SIZE=20            # leads considered per scheduler tick
RETELL_STALE_CALL_TTL_MS=600000           # reap In_Progress rows stuck past this

# --- Dashboard (dashboard/.env.local) ----------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=               # same project as SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY=          # publishable/anon key (browser-safe)
# SUPABASE_SERVICE_ROLE_KEY=              # server-only, for admin reads/writes
# DASHBOARD_ACCESS_PASSWORD=              # simple gate for the standalone dashboard
