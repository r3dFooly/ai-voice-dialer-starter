# Supabase — voice dialer database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard admin gate — password required to access admin views + server actions
DASHBOARD_ACCESS_PASSWORD=change-me

# --- Optional branding / labels (neutral defaults used when unset) ---
# NEXT_PUBLIC_APP_NAME=Voice Dialer
# NEXT_PUBLIC_AGENT_NAME=the voice dialer
# Comma-separated code:label pairs for the agent-code -> display-name map.
# NEXT_PUBLIC_AGENT_NAMES=
# Comma-separated tier labels (4 entries: tier1,tier2,tier3,other).
# NEXT_PUBLIC_TIER_LABELS=Tier 1,Tier 2,Tier 3,Other
# NEXT_PUBLIC_SEGMENT_LABEL=Segment
